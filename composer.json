{
    "name": "simply-stream/twitch-api",
    "description": "",
    "license": "MIT",
    "authors": [
        {
            "name": "TobiDev",
            "email": "info@simply-stream.com"
        }
    ],
    "require": {
        "php": "^8.4",
        "ext-json": "*",
        "psr/http-client": "^1.0",
        "psr/http-factory": "^1.0",
        "psr/log": "^3.0",
        "webmozart/assert": "^2.0.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.2",
        "phpstan/phpstan": "^2.2",
        "nyholm/psr7": "^1.8",
        "php-http/discovery": "^1.20",
        "friendsofphp/php-cs-fixer": "^v3.95",
        "symfony/serializer": "^8.1",
        "symfony/property-info": "^8.1",
        "symfony/property-access": "^8.1",
        "phpdocumentor/reflection-docblock": "^6.0"
    },
    "suggest": {
        "nyholm/psr7": "^1.8",
        "guzzlehttp/guzzle": "^7.8"
    },
    "autoload": {
        "psr-4": {
            "SimplyStream\\TwitchApi\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SimplyStream\\TwitchApi\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true
        }
    }
}
